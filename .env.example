LDAP_DOMAIN=girahub.local
LDAP_ADMIN_PASSWORD=ldap_admin_pass
LDAP_TLS=false

# ==========================================
# Configuración Grafana
# ==========================================
GF_SECURITY_ADMIN_PASSWORD=grafana_password_placeholder

